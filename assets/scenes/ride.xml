<?xml version="1.0"?>
<scene>
	<partitions>
		<partition name="GUI" />
		<partition name="Objects" />
		<partition name="Grid" />
	</partitions>

	<entities>
		<entity>
			<components>
				<component name="ColorGrid" />
			</components>
			<properties>
				<string name="Name">Grid</string>
				<list name="Rect">20, 0, 492, 502</list>
				<number name="NumRows">7</number>
				<number name="HorizontalGap">35</number>
				<number name="VerticalGap">25</number>
				<number name="LineWidth">8</number>
				<string name="PartitionName">Grid</string>
				<string name="UpdatePhase">GameLogic</string>
			</properties>
		</entity>

		<entity>
			<components>
				<preset name="glider/Mesh" />
				<component name="Track" />
			</components>
			<properties>
				<string name="Name">Track</string>
				<string name="UpdatePhase">GameLogic</string>
				<string name="PartitionName">Objects</string>
			</properties>
		</entity>

		<entity>
			<components>
				<component name="RideController" />
			</components>
			<properties>
				<string name="Name">RideController</string>
				<string name="UpdatePhase">Controller</string>
			</properties>
		</entity>

		<entity>
			<components>
				<preset name="glider/Mesh" />
				<component name="Ship" />
				<component name="BeatRider" />
			</components>
			<properties>
				<string name="Name">Ship</string>
				<string name="PartitionName">Objects</string>
				<string name="DeckName">mesh:spaceship.dae</string>
				<string name="UpdatePhase">GameLogic</string>
				<string name="RotationMode">base</string>
				<number name="Y">5</number>
			</properties>
		</entity>

		<entity>
			<components>
				<preset name="glider/Camera" />
				<component name="BeatRider" />
				<component name="RideCamera" />
			</components>
			<properties>
				<string name="Name">MainCamera</string>
				<number name="Y">60</number>
				<number name="Z">120</number>
				<number name="XRotation">-14</number>
				<number name="TrackOffset">-0.02</number>
				<string name="RotationMode">base</string>
				<string name="UpdatePhase">GameLogic</string>
			</properties>
		</entity>

		<preset name="glider/Text">
			<string name="Name">txtProgress</string>
			<string name="PartitionName">GUI</string>
			<string name="FontName">hermit.ttf</string>
			<number name="FontSize">20</number>
			<list name="TextRect">0, 0, 200, 200</list>
			<list name="TextAlignment">left, top</list>
			<string name="Text"> yolo </string>
		</preset>
	</entities>

	<viewports>
		<viewport name="Default" />
		<viewport name="GUI" y-scale="-1" x-offset="-1" y-offset="1" />
		<viewport name="Grid" width="512" height="512" x-offset="-1" y-offset="-1" mode="absolute" />
	</viewports>

	<render-tables>
		<render-table name="main">
			<layer partition="Objects" viewport="Default" camera="MainCamera" />
			<layer partition="GUI" viewport="GUI" />
		</render-table>
		<render-table name="grid">
			<layer partition="Grid" viewport="Grid" />
		</render-table>
	</render-tables>

	<frame-buffers>
		<frame-buffer name="grid" width="512" height="512" render-table="grid" />
	</frame-buffers>
</scene>
